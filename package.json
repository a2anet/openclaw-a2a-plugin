{
    "name": "@a2anet/openclaw-a2a-plugin",
    "version": "0.1.0",
    "description": "OpenClaw A2A protocol community plugin. Send messages and files to other agents over the internet, and allow other people to connect to your agent with Tailscale",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": ["dist"],
    "scripts": {
        "build": "tsc",
        "check": "biome check .",
        "check:fix": "biome check --write .",
        "typecheck": "tsc --noEmit",
        "test": "bun test",
        "test:coverage": "bun test --coverage"
    },
    "keywords": ["a2a", "agent-to-agent", "openclaw", "plugin", "tailscale"],
    "author": "A2A Net <hello@a2anet.com>",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/a2anet/openclaw-a2a-plugin.git"
    },
    "bugs": {
        "url": "https://github.com/a2anet/openclaw-a2a-plugin/issues"
    },
    "homepage": "https://github.com/a2anet/openclaw-a2a-plugin#readme",
    "devDependencies": {
        "@biomejs/biome": "^1.9.0",
        "@types/bun": "latest",
        "typescript": "^5.7.0"
    },
    "trustedDependencies": ["@biomejs/biome"]
}
