{
    "name": "@a2anet/openclaw-a2a-plugin",
    "version": "0.1.0",
    "description": "A2A protocol plugin for OpenClaw. Send messages to remote A2A agents and allow others to connect to your agent.",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": ["dist", "openclaw.plugin.json"],
    "scripts": {
        "build": "tsc",
        "check": "biome check .",
        "check:fix": "biome check --write .",
        "typecheck": "tsc --noEmit",
        "test": "bun test",
        "test:coverage": "bun test --coverage"
    },
    "openclaw": {
        "extensions": ["./dist/index.js"]
    },
    "keywords": ["a2a", "agent-to-agent", "openclaw", "plugin"],
    "author": "A2A Net <hello@a2anet.com>",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/a2anet/openclaw-a2a-plugin.git"
    },
    "bugs": {
        "url": "https://github.com/a2anet/openclaw-a2a-plugin/issues"
    },
    "homepage": "https://github.com/a2anet/openclaw-a2a-plugin#readme",
    "dependencies": {
        "@a2a-js/sdk": "^0.3.10",
        "@a2anet/a2a-utils": "^0.7.2",
        "@sinclair/typebox": "^0.34.0",
        "ws": "^8.19.0",
        "zod": "^3.25.0",
        "zod-to-json-schema": "^3.25.1"
    },
    "peerDependencies": {
        "openclaw": ">=2026.4.8"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.0",
        "@types/bun": "latest",
        "@types/ws": "^8.0.0",
        "openclaw": "^2026.4.8",
        "typescript": "^5.7.0"
    },
    "trustedDependencies": ["@biomejs/biome"]
}
